APP_NAME=DropKey
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://passshare.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12
HASH_DRIVER=argon2id
ARGON_MEMORY=131072
ARGON_THREADS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=passshare
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=5
SESSION_ENCRYPT=true
SESSION_EXPIRE_ON_CLOSE=true
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Docker/production: internal HTTP API for Laravel -> Reverb (defaults to REVERB_* above).
REVERB_BROADCAST_HOST=127.0.0.1
REVERB_BROADCAST_PORT=8081
REVERB_BROADCAST_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#same format as APP_KEY
PASSKEYS_USER_HANDLE_SECRET=

# Leave empty for local/Herd. Docker with Cloudflare Tunnel: 127.0.0.1 (nginx is the only upstream proxy).
TRUSTED_PROXIES=

SEND_CACHE_TTL=60
MAX_MESSAGE_LENGTH=1000
ENCRYPTED_MAX_MESSAGE_LENGTH=5372
MAX_SENDS_PER_USER=15

POLICY_DENIAL_LOGGING_ENABLED=true
POLICY_DENIAL_LOG_MAX_PER_MINUTE=10
POLICY_DENIAL_LOG_GLOBAL_MAX_PER_MINUTE=100
POLICY_DENIAL_LOG_THROTTLE_BY=ip

PULSE_ENABLED=true
PULSE_ADMIN_EMAIL=levongabrielyan44@gmail.com
PULSE_CACHE_DRIVER=array
PULSE_USER_REQUESTS_ENABLED=true
PULSE_USER_JOBS_ENABLED=true

RESEND_API_KEY=

# Cloudflare Turnstile (optional locally; required in production for registration, login, and password reset)
TURNSTILE_SITE_KEY=1x00000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Web Push (VAPID) — generate with: php artisan webpush:vapid
VAPID_SUBJECT="${APP_URL}"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
