[mariadb]
# Transparent Data Encryption (TDE) — full at-rest encryption for production.
# Keys are provisioned by docker/mariadb/prepare-encryption-keys.sh into
# /etc/mysql/encryption (mariadb-encryption volume).

plugin_load_add = file_key_management
file_key_management_filename = /etc/mysql/encryption/keyfile
file_key_management_encryption_algorithm = AES_CTR

innodb_default_encryption_key_id = 1
innodb_encrypt_tables = FORCE
innodb_encrypt_log = ON
innodb_encrypt_temporary_tables = ON
innodb_encryption_threads = 4

aria_encrypt_tables = ON

encrypt_tmp_disk_tables = ON
encrypt_tmp_files = ON
encrypt_binlog = ON
